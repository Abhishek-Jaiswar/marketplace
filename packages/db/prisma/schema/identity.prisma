enum UserStatus {
  ACTIVE
  UNVERIFIED
  SUSPENDED
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
  APPLE
}

model User {
  id        String     @id @default(cuid())
  firstName String
  lastName  String?
  email     String     @unique
  avatar    String?
  status    UserStatus @default(UNVERIFIED)
  roles     UserRole[] @default([CUSTOMER])
  emailVerified Boolean    @default(false)

  emailVerifiedAt DateTime?
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  credential         Credential?
  sessions           Session[]
  verificationTokens VerificationToken[]
  seller             Seller?
  uploadedMedia      Media[]

  @@index([status])
}


model Credential {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider AuthProvider @default(CREDENTIALS)

  passwordHash      String
  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String @unique

  expiresAt    DateTime
  lastActivity DateTime @default(now())

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String                @unique
  type      VerificationTokenType

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
}
